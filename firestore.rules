rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Listings — only signed-in @bu.edu users can read/write their own listing
    match /listings/{userId} {
      allow read: if request.auth != null
                  && request.auth.token.email.matches(".*@bu\\.edu");

      allow create: if request.auth != null
                    && request.auth.uid == userId
                    && request.auth.token.email.matches(".*@bu\\.edu");

      allow update, delete: if request.auth != null
                            && request.auth.uid == userId;
    }

    // Contacts — only signed-in @bu.edu users can read, owner can write
    match /contacts/{userId} {
      allow read: if request.auth != null
                  && request.auth.token.email.matches(".*@bu\\.edu");

      allow create: if request.auth != null
                    && request.auth.uid == userId
                    && request.auth.token.email.matches(".*@bu\\.edu");

      allow update, delete: if request.auth != null
                            && request.auth.uid == userId;
    }
  }
}